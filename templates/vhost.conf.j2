# Virtual Host configuration for {{ item.domain }} - Managed by Martin Chunga through Ansible
<VirtualHost *:80>
    ServerName {{ item.domain }}
    ServerAdmin {{ apache_server_admin | default('webmaster@localhost') }}
    DocumentRoot /var/www/{{ item.domain }}/public_html

    <Directory /var/www/{{ item.domain }}/public_html>
        Options -Indexes +FollowSymLinks
        AllowOverride All
        Require all granted
    </Directory>

    # Use the log directory we created earlier
    ErrorLog /etc/apache2/logs/{{ item.domain }}_error.log
    CustomLog /etc/apache2/logs/{{ item.domain }}_access.log combined

    # Security: Disable TRACE for this vhost
    TraceEnable Off
</VirtualHost>
